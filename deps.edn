{:paths ["src"]
 ;; kotoba-lang/http — Layer 3 (I/O) of the kotoba foundational stdlib.
 ;; Request/response data model + pure parse-url + an IHttp protocol the HOST
 ;; injects (no baked-in HTTP client) so it runs on kotoba-WASM. Zero
 ;; third-party runtime deps; .cljc. See ADR-kotoba-lang-foundational-stdlib.md.
 :deps {}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}}}
